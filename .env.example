# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NOTE: The primary way Claude reaches Slack and Google Drive is the claude.ai
# MCP connectors (no keys needed here). The variables below are (a) config
# placeholders Claude reads, and (b) optional slots for future direct-API use.

# --- Config placeholders (fill these in) ---

# The single Slack channel Claude sends report summaries to (send-only).
# Example: #weekly-reports  or a channel ID like C0123456789
SLACK_TARGET_CHANNEL=

# The Google Drive folder where finished reports are uploaded.
# Paste the shareable folder URL.
GDRIVE_REPORTS_FOLDER_URL=

# --- Optional: only needed if you ever switch from MCP connectors to raw APIs ---

# Slack (direct API) — leave blank when using the MCP connector.
# SLACK_BOT_TOKEN=

# Google (direct API) — leave blank when using the MCP connector.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
